<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:text="🔊"
        android:textSize="56sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:text="Float Volume"
        android:textSize="28sp"
        android:textColor="#00D4FF"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:textSize="15sp"
        android:textColor="#AAFFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:text="Grant overlay permission to use the floating volume knob."/>

    <Button
        android:id="@+id/btnStart"
        android:text="Enable Floating Knob"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#00D4FF"
        android:textColor="#1A1A2E"
        android:textStyle="bold"
        android:paddingHorizontal="28dp"
        android:paddingVertical="12dp"/>

    <TextView
        android:text="Tap the glowing dot on screen to expand the knob.\nTap top half → Volume Up\nTap bottom half → Volume Down\nDrag to reposition."
        android:textSize="13sp"
        android:textColor="#66FFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="28dp"/>

</LinearLayout>
